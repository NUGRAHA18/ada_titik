{
  "env": {
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "ignoreRestSiblings": true }],
    "no-console": "off",
    "no-undef": "error"
  },
  "overrides": [
    {
      "files": ["src/tests/**/*.test.js"],
      "env": {
        "jest": true
      }
    }
  ]
}
