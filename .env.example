# Environment: development | staging | production
NODE_ENV=development

# Konfigurasi Server
PORT=3000

# Konfigurasi Database PostgreSQL (Pastikan ekstensi PostGIS aktif)
# Format: postgres://<username>:<password>@<host>:<port>/<nama_database>
DATABASE_URL=postgres://postgres:password_anda@localhost:5432/titik_baik

# Keamanan (JWT)
# Gunakan string acak yang panjang dan rumit di production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=rahasia_titik_baik_super_aman

# CORS - Whitelist origins untuk production (pisahkan dengan koma)
# Contoh: https://app.titikbaik.id,https://admin.titikbaik.id
# Di development, ALLOWED_ORIGINS diabaikan dan semua origin diizinkan
ALLOWED_ORIGINS=https://app.titikbaik.id
