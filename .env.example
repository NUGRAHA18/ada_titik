# ── Environment ───────────────────────────────────────────────────────────────
# development | staging | production
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Lokal (tanpa Docker):
DATABASE_URL=postgres://postgres:password_anda@localhost:5432/titik_baik

# Docker — host 'db' sesuai nama service di docker-compose.yml
# DATABASE_URL akan di-override otomatis oleh docker-compose, tidak perlu diubah manual.
# Cukup set DB_PASSWORD di bawah:
DB_PASSWORD=ganti_dengan_password_aman

# ── Keamanan JWT ──────────────────────────────────────────────────────────────
# Generate di terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_string_acak_panjang_dan_rumit

# ── CORS ──────────────────────────────────────────────────────────────────────
# Whitelist origin Flutter app (production only, pisahkan dengan koma)
# Di development semua origin diizinkan secara otomatis.
ALLOWED_ORIGINS=url_frontend
